{
  "name": "eink-devdash",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,readonly",
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind,readonly"
  ],
  // Port 3000 = API server, port 8080 = web flasher (served locally, WebSerial flashes via local browser)
  "forwardPorts": [3000, 8080],
  "portsAttributes": {
    "3000": { "label": "API server" },
    "8080": { "label": "Web flasher" }
  },
  "remoteUser": "root",
  "postCreateCommand": "cd /workspace/api && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "espressif.esp-idf-extension"
      ],
      "settings": {
        "idf.espIdfPath": "/opt/esp/idf",
        "idf.customExtraPaths": "/opt/esp/tools/bin"
      }
    }
  }
}
