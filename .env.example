# Required
DEVICE_TOKEN=replace-with-a-random-device-secret

# Container UID/GID — set to the host user that owns ~/.claude so the API
# can refresh the OAuth token in place. Run `id -u` / `id -g` to find them.
HOST_UID=1000
HOST_GID=1000

# Optional
CODE_HOST_PROVIDER=

# Repository counters: issues, pull requests, and Dependabot alerts.
# Fine-grained PATs need the "Dependabot alerts" repository permission set to
# read. Classic PATs need `security_events`; use `repo` only when private
# repository issues/PRs must be counted.
GITHUB_TOKEN=

# Unread notifications. Must be a classic PAT with `notifications` scope;
# fine-grained PATs do not work with GitHub's notifications API. Leave empty
# to hide INBOX on the display.
GITHUB_NOTIFICATIONS_TOKEN=

# GitLab is reserved in the API config shape. It does not emit a service yet.
GITLAB_TOKEN=
GITLAB_BASE_URL=

CODEX_PLAN_TYPE=
CODEX_LIVE_USAGE=true
CODEX_CLI_PATH=
CODEX_APP_SERVER_TIMEOUT_MS=8000
DASHBOARD_TIME_ZONE=Europe/Amsterdam
MDNS_ENABLED=true
MDNS_NAME=devdash-api

# Optional Cloudflare relay. Leave disabled for LAN-only operation.
RELAY_ENABLED=false
RELAY_URL=
RELAY_PUBLISH_KEY=
RELAY_ADMIN_KEY=
DEVICE_UUID=
RELAY_RECONNECT_MIN_MS=1000
RELAY_RECONNECT_MAX_MS=60000
RELAY_HEARTBEAT_INTERVAL_MS=30000
RELAY_HEARTBEAT_TIMEOUT_MS=10000

# Set to "false" to make /ota/manifest always return {otaEnabled:false}
# even when APP_VERSION is baked into the image. Useful for pinning a
# device to the currently-installed firmware.
OTA_ENABLED=true

# Image tag to pull from ghcr.io/harmellis/eink-devdash (defaults to "latest")
IMAGE_TAG=latest
