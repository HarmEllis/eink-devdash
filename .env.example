# Required
DEVICE_TOKEN=replace-with-a-random-device-secret

# Container UID/GID — set to the host user that owns ~/.claude so the API
# can refresh the OAuth token in place. Run `id -u` / `id -g` to find them.
HOST_UID=1000
HOST_GID=1000

# Optional
CODE_HOST_PROVIDER=

# Repository counters: issues, pull requests, and Dependabot alerts.
# Fine-grained PATs need the "Dependabot alerts" repository permission set to
# read. Classic PATs need `security_events`; use `repo` only when private
# repository issues/PRs must be counted.
GITHUB_TOKEN=

# Unread notifications. Must be a classic PAT with `notifications` scope;
# fine-grained PATs do not work with GitHub's notifications API. Leave empty
# to hide INBOX on the display.
GITHUB_NOTIFICATIONS_TOKEN=

# GitLab is reserved in the API config shape. It does not emit a service yet.
GITLAB_TOKEN=
GITLAB_BASE_URL=

CODEX_PLAN_TYPE=
CODEX_LIVE_USAGE=true
CODEX_CLI_PATH=
CODEX_APP_SERVER_TIMEOUT_MS=8000

# Manual overage spend in USD for the Codex extra-usage bar. ChatGPT-auth exposes
# no dollar figure, so set this by hand. Empty (or 0) hides the bar; a value > 0
# renders a `$` symbol, an amount-capped bar (filling up to $100), and the amount.
CODEX_OVERAGE_USD=

# Optional override for the Claude extra-usage bar. Claude's OAuth usage credits
# are read live (currency symbol, bar = % of the monthly cap, amount consumed), so
# leave this empty. If set (> 0) it overrides the live read with a manual USD
# amount-capped bar, matching CODEX_OVERAGE_USD behaviour.
CLAUDE_OVERAGE_USD=

# Optional direct access token or credential-file override. Normally both stay
# empty and the API reads ~/.gemini/antigravity-cli/antigravity-oauth-token.
ANTIGRAVITY_TOKEN=
ANTIGRAVITY_TOKEN_PATH=

# Manual overage spend in USD for the Antigravity (Google AI Pro) extra-usage bar.
# Shows up when a value > 0 is provided.
ANTIGRAVITY_OVERAGE_USD=

# BCP-47 locale used to format the extra-usage amount (decimal separator), e.g.
# nl-NL -> "0,91", en-US -> "0.91". Defaults to nl-NL. Invalid/unsupported
# values fall back to the default.
DASHBOARD_LOCALE=nl-NL
DASHBOARD_TIME_ZONE=Europe/Amsterdam

# Recommended daily-limit tick on the 7-day usage bar. Empty = no tick.
#   ceiling   -> today's recommended ceiling: current usage plus an equal share
#                of the remaining weekly budget spread over the remaining days.
#   even-pace -> where usage should be by now if spread evenly across the week.
WEEK_TICK_MODE=

# Days you actually use your quota, for the WEEK_TICK_MODE calculation above.
# Comma-separated weekday abbreviations; empty = all 7 days. Day boundaries use
# DASHBOARD_TIME_ZONE. Example for a Mon/Tue/Thu/Fri work week:
# WORK_DAYS=mon,tue,thu,fri
WORK_DAYS=

MDNS_ENABLED=true
MDNS_NAME=devdash-api

# Optional Cloudflare relay. Leave disabled for LAN-only operation.
RELAY_ENABLED=false
RELAY_URL=
RELAY_PUBLISH_KEY=
RELAY_ADMIN_KEY=
DEVICE_UUID=
RELAY_RECONNECT_MIN_MS=1000
RELAY_RECONNECT_MAX_MS=60000
RELAY_HEARTBEAT_INTERVAL_MS=30000
RELAY_HEARTBEAT_TIMEOUT_MS=10000

# Set to "false" to make /ota/manifest always return {otaEnabled:false}
# even when APP_VERSION is baked into the image. Useful for pinning a
# device to the currently-installed firmware.
OTA_ENABLED=true

# Image tag to pull from ghcr.io/harmellis/eink-devdash (defaults to "latest")
IMAGE_TAG=latest
