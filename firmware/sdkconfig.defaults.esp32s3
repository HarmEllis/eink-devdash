# ESP32-S3 Super Mini specifics
CONFIG_IDF_TARGET_ESP32S3=y
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y

# SPI pins — WeAct 2.9" e-paper wired to ESP32-S3 Super Mini
# SDA(MOSI)=GP11, SCL(SCK)=GP12, CS=GP10, D/C=GP9, RES=GP1, BUSY=GP13
# MISO unused (-1), VCC=3V3 (NOT 5V)
CONFIG_EINK_SPI_MOSI=11
CONFIG_EINK_SPI_SCK=12
CONFIG_EINK_SPI_CS=10
CONFIG_EINK_DC_PIN=9
CONFIG_EINK_RST_PIN=1
CONFIG_EINK_BUSY_PIN=13
