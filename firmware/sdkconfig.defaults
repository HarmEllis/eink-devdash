# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Partition layout: custom 2-slot OTA CSV (firmware/partitions.csv) so the
# device can pull OTA updates from the local API + GitHub Releases. ESP-IDF's
# stock TWO_OTA preset uses 1 MB slots plus a 1 MB factory partition; our
# binary is ~1.07 MB once esp_https_ota + the mbedtls cert bundle are linked
# in, so we ship a slightly larger 1.5 MB / 1.5 MB layout. Migrating from
# SINGLE_APP_LARGE shifts the app region, so the first install of an
# OTA-capable image triggers a webflasher erase prompt and the user
# re-provisions Wi-Fi + API token once. See docs/decisions/0005-ota-updates.md.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# OTA download path: bundled Mozilla root CAs so esp_https_ota can validate
# github.com / objects.githubusercontent.com without shipping a per-host PEM.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y

# Mark a newly OTA-installed image as PENDING_VERIFY at boot; firmware calls
# esp_ota_mark_app_valid_cancel_rollback() once a fetch + render succeeds.
# A crash/reset before that point reverts to the previous slot automatically.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Main task stack: default 3584 B is for trivial main tasks. app_main here
# runs Wi-Fi setup, API fetch, JSON parse, and display rendering on the main
# task. 8 KiB matches typical ESP-IDF wifi-station examples and leaves room
# for the dashboard fetch/render path.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# WiFi
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y

# ESP32-S3 Super Mini exposes the built-in USB-Serial-JTAG CDC port. We use it
# as a secondary log console so plugging USB gives the same log stream as a
# wired UART adapter. UART0 stays the primary console.
# CONFIG_ESP_CONSOLE_SECONDARY_NONE is not set
CONFIG_ESP_CONSOLE_SECONDARY_USB_SERIAL_JTAG=y

# Panel SKU. The repo dev / CI build targets the WeAct 2.9" BWR module (0).
# Per-SKU factory builds override this (0=BWR, 1=BW); see Gate 0.B in
# BOARD_NOTES. Leaving it at the Kconfig sentinel (-1) fails the build closed.
CONFIG_DEVDASH_DEFAULT_PANEL_VARIANT=0

# Deep sleep
CONFIG_PM_ENABLE=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y

# NVS encryption off (home LAN use case)
CONFIG_NVS_ENCRYPTION=n

# SoftAP compatibility (ESP32-S3): Espressif's Wi-Fi FAQ recommends disabling
# AMPDU RX/TX to fix ESP32-S2/S3 SoftAP incompatibility with phones/PCs (a
# started-but-undetectable SoftAP). Paired with dropping the AP to 11b/g (no
# 11n/AMPDU) in run_provisioning_window. Negligible throughput impact for this
# low-bandwidth dashboard. See ESP-IDF issue #13508.
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=n

# HTTPD / provisioning portal
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024

# Task stacks bumped for the SoftAP captive-portal flow. Defaults are tuned
# for a station-only build; with SoftAP + DHCP server + captive DNS + httpd
# all active during provisioning, several tasks need more headroom. A
# context-switch StoreProhibited tracked back to a corrupted CP-save-area
# pointer (a task overflowed and trampled its own TCB metadata).
CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=5120
CONFIG_ESP_IPC_TASK_STACK_SIZE=4096
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_ESP_TIMER_TASK_STACK_SIZE=4608

# Trace facility lets us call uxTaskGetSystemState() to log per-task stack
# high-water-marks during provisioning, so the next round of debugging can
# pinpoint the overflow culprit instead of guessing.
CONFIG_FREERTOS_USE_TRACE_FACILITY=y

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Demo
CONFIG_DEVDASH_DEMO_MODE=n
